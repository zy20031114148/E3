.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  border-top: 2rpx solid #f0f0f0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}
.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}
.tabbar-item.active .tabbar-icon { transform: scale(1.1); }
.tabbar-item.active .tabbar-text { color: #1a7cee; font-weight: 500; }
.tabbar-icon {
  font-size: 44rpx;
  margin-bottom: 6rpx;
  transition: transform 0.2s;
}
.tabbar-text {
  font-size: 20rpx;
  color: #999;
  transition: color 0.2s;
}
