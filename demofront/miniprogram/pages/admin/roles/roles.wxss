.page { padding-bottom: 40rpx; }
.role-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.role-name { font-size: 30rpx; font-weight: 500; }
.expand-icon { font-size: 24rpx; color: #999; }
.perm-list { margin-top: 20rpx; padding-top: 20rpx; border-top: 2rpx solid #f0f0f0; }
.perm-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  font-size: 26rpx;
}
.perm-name { margin-left: 12rpx; color: #555; }
.save-area {
  padding: 30rpx;
  text-align: center;
}
.btn-primary {
  width: 100%;
  padding: 24rpx 0;
  background: #1a7cee;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #fff;
  border: none;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
