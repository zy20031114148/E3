<view class="page has-tabbar">
  <view class="card">
    <view class="section-title">公司信息</view>
    <view class="input-group">
      <text class="input-label">公司名称</text>
      <input class="input-field" value="{{settings.companyName}}" bindinput="onFieldChange" data-field="companyName"></input>
    </view>
    <view class="input-group">
      <text class="input-label">联系电话</text>
      <input class="input-field" value="{{settings.contactPhone}}" bindinput="onFieldChange" data-field="contactPhone"></input>
    </view>
    <view class="input-group">
      <text class="input-label">公司地址</text>
      <input class="input-field" value="{{settings.address}}" bindinput="onFieldChange" data-field="address"></input>
    </view>
    <view class="input-group">
      <text class="input-label">工作时间</text>
      <input class="input-field" value="{{settings.workingHours}}" bindinput="onFieldChange" data-field="workingHours"></input>
    </view>
    <view class="input-group">
      <text class="input-label">访客须知</text>
      <textarea class="textarea-field" value="{{settings.visitorNotice}}" bindinput="onFieldChange" data-field="visitorNotice"></textarea>
    </view>
    <button class="btn-primary" bindtap="onSave">保存设置</button>
  </view>

  <view class="card">
    <view class="section-title">系统管理</view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/admin/roles/roles">
      <text class="menu-text">角色权限管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/admin/admins/admins">
      <text class="menu-text">管理员管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/admin/holiday/holiday">
      <text class="menu-text">节假日设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/admin/notify-mgr/notify-mgr">
      <text class="menu-text">通知管理</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
<tabBar activeTab="4"></tabBar>
