<view class="page has-tabbar">
  <view class="stats-grid">
    <view class="stats-card blue">
      <text class="stats-num">{{overview.todayAppointments}}</text>
      <text class="stats-label">今日预约</text>
    </view>
    <view class="stats-card orange">
      <text class="stats-num">{{overview.pendingApprovals}}</text>
      <text class="stats-label">待审核</text>
    </view>
    <view class="stats-card green">
      <text class="stats-num">{{overview.totalEmployees}}</text>
      <text class="stats-label">员工总数</text>
    </view>
    <view class="stats-card purple">
      <text class="stats-num">{{overview.totalDepartments}}</text>
      <text class="stats-label">部门数</text>
    </view>
  </view>

  <view class="card">
    <view class="section-title">近7日预约趋势</view>
    <view class="chart-placeholder">
      <block wx:for="{{trend}}" wx:key="date">
        <view class="bar-item">
          <view class="bar" style="height: {{maxBar > 0 ? (item.count / maxBar) * 200 : 0}}rpx"></view>
          <text class="bar-label">{{item.date.slice(5)}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="card">
    <view class="section-title">来访单位排名</view>
    <block wx:for="{{companyRank}}" wx:key="name">
      <view class="rank-item">
        <text class="rank-name">{{item.name}}</text>
        <view class="rank-bar-bg">
          <view class="rank-bar" style="width: {{maxCount > 0 ? (item.count / maxCount) * 100 : 0}}%"></view>
        </view>
        <text class="rank-count">{{item.count}}次</text>
      </view>
    </block>
  </view>
</view>
<tabBar activeTab="3"></tabBar>
