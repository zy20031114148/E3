<view class="page has-tabbar">
  <view class="tabs">
    <view class="tab {{currentTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="switchTab">全部</view>
    <view class="tab {{currentTab === 'pending' ? 'active' : ''}}" data-tab="pending" bindtap="switchTab">待审核</view>
  </view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card">
      <view class="record-header">
        <text class="record-company">{{item.company}}</text>
        <text class="tag tag-{{item.status}}">{{statusMap[item.status]}}</text>
      </view>
      <view class="record-body">
        <view class="info-row"><text class="label">访客：</text><text>{{item.visitorName}}</text></view>
        <view class="info-row"><text class="label">被访：</text><text>{{item.hostName}}</text></view>
        <view class="info-row"><text class="label">事由：</text><text>{{item.purpose}}</text></view>
        <view class="info-row"><text class="label">时间：</text><text>{{item.startTime}}</text></view>
      </view>
      <view class="record-actions" wx:if="{{item.status === 'pending'}}">
        <button class="btn-reject" bindtap="onReject" data-id="{{item.id}}">拒绝</button>
        <button class="btn-approve" bindtap="onApprove" data-id="{{item.id}}">通过</button>
      </view>
    </view>
  </block>
  <view class="empty-state" wx:if="{{list.length === 0}}">暂无预约记录</view>

  <view class="card">
    <view class="menu-item" bindtap="goNotifyMgr">
      <text class="menu-text">📢 通知管理（发布/编辑/删除）</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
<tabBar activeTab="2"></tabBar>
