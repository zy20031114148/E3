<view class="page">
  <view class="card">
    <view class="flex-header">
      <text class="section-title">管理员列表</text>
      <button class="add-btn" bindtap="onAdd">+ 新增</button>
    </view>
    <block wx:for="{{list}}" wx:key="id">
      <view class="list-item">
        <view>
          <text class="admin-name">{{item.name}}</text>
          <view class="admin-meta">{{item.username}} · {{item.phone}}</view>
        </view>
        <view class="emp-actions">
          <text class="action-btn" bindtap="onEdit" data-item="{{item}}">编辑</text>
          <text class="action-btn action-del" bindtap="onDelete" data-id="{{item.id}}" wx:if="{{item.username !== 'admin'}}">删除</text>
        </view>
      </view>
    </block>
  </view>
</view>
