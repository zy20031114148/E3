<view class="page has-tabbar">
  <view class="scan-area">
    <view class="scan-icon-frame">
      <view class="scan-icon">📷</view>
    </view>
    <text class="scan-tip">请扫描访客的预约二维码</text>
    <button class="btn-primary scan-btn" bindtap="onScan">扫 码 核 验</button>
    <text class="manual-hint" bindtap="onManualInput">或手动输入预约ID</text>
  </view>

  <view class="card result-card" wx:if="{{showResult}}">
    <view class="result-status {{result.valid ? 'success' : 'fail'}}">
      <text class="result-icon">{{result.valid ? '✅' : '❌'}}</text>
      <text class="result-msg">{{result.message}}</text>
    </view>
    <view class="result-body" wx:if="{{result.valid}}">
      <view class="info-row"><text class="label">访客：</text><text>{{result.visitorName}}</text></view>
      <view class="info-row"><text class="label">单位：</text><text>{{result.company}}</text></view>
      <view class="info-row"><text class="label">被访人：</text><text>{{result.hostName}}</text></view>
      <view class="info-row"><text class="label">时间：</text><text>{{result.time}}</text></view>
    </view>
    <button class="btn-primary confirm-btn" wx:if="{{result.valid && !result.confirmed}}" bindtap="onConfirm">确认放行</button>
    <view class="confirmed-tag" wx:if="{{result.confirmed}}">✅ 已放行</view>
  </view>
</view>
<tabBar activeTab="0"></tabBar>
