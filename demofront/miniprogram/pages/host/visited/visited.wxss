.page { padding-bottom: 40rpx; }

.stats-overview {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.stat-item {
  text-align: center;
}
.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #1a7cee;
}
.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  color: #333;
}

.record-name {
  font-size: 28rpx;
  font-weight: 500;
}
.record-company {
  font-size: 26rpx;
  color: #888;
}
.record-meta {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 8rpx;
}
