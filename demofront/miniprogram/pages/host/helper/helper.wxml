<view class="page">
  <view class="card">
    <view class="section-title">为访客代填预约</view>

    <view class="input-group">
      <text class="input-label">访客姓名</text>
      <input class="input-field" placeholder="请输入访客姓名" value="{{form.visitorName}}" bindinput="onFieldChange" data-field="visitorName"></input>
    </view>
    <view class="input-group">
      <text class="input-label">手机号</text>
      <input class="input-field" type="number" placeholder="请输入访客手机号" value="{{form.visitorPhone}}" bindinput="onFieldChange" data-field="visitorPhone"></input>
    </view>
    <view class="input-group">
      <text class="input-label">来访单位</text>
      <input class="input-field" placeholder="请输入单位名称" value="{{form.company}}" bindinput="onFieldChange" data-field="company"></input>
    </view>
    <view class="input-group">
      <text class="input-label">来访事由</text>
      <input class="input-field" placeholder="请输入来访事由" value="{{form.purpose}}" bindinput="onFieldChange" data-field="purpose"></input>
    </view>
    <view class="input-group">
      <text class="input-label">到访时间</text>
      <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
        <view class="picker-value">{{form.date || '请选择日期'}}</view>
      </picker>
    </view>
  </view>

  <view class="submit-area">
    <button class="btn-primary" bindtap="onSubmit" loading="{{submitting}}">提交预约</button>
  </view>
</view>
