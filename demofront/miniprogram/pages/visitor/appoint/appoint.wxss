.page {
  height: 100vh;
}

.picker {
  width: 100%;
  height: 80rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  line-height: 80rpx;
  border: 2rpx solid #e8e8e8;
  box-sizing: border-box;
}

.picker-value {
  color: #333;
  font-size: 28rpx;
}

.textarea-field {
  width: 100%;
  height: 160rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #e8e8e8;
}

.submit-area {
  padding: 30rpx 30rpx 60rpx;
}

.stepper {
  display: inline-block;
}
