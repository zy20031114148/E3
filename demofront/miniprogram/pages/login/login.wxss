.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a7cee 0%, #3b9eff 40%, #f5f6fa 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.2);
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  color: #fff;
  font-weight: 600;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
}

.login-form {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.08);
}

.login-btn {
  width: 100%;
  margin-top: 40rpx;
}

.hint-text {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 30rpx;
}
