<view class="page has-tabbar">
  <view class="stats-overview">
    <view class="stat-item">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-label">总来访</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.thisMonth}}</text>
      <text class="stat-label">本月</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.companies}}</text>
      <text class="stat-label">来访单位</text>
    </view>
  </view>

  <view class="card">
    <view class="section-title">近期被访记录</view>
    <block wx:for="{{list}}" wx:key="id">
      <view class="list-item">
        <view>
          <text class="record-name">{{item.visitorName}}</text>
          <text class="record-company"> | {{item.company}}</text>
          <view class="record-meta">{{item.purpose}} · {{item.startTime}}</view>
        </view>
        <text class="tag tag-{{item.status}}">{{statusMap[item.status]}}</text>
      </view>
    </block>
  </view>

  <view class="card" style="margin-top: 0;">
    <view class="menu-item" bindtap="goHelper">
      <text class="menu-text">➕ 辅助预约（代访客预约）</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
<tabBar activeTab="0"></tabBar>
