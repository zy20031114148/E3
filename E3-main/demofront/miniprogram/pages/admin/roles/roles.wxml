<view class="page">
  <block wx:for="{{roles}}" wx:key="id" wx:for-item="role">
    <view class="card">
      <view class="role-header" bindtap="toggleExpand" data-id="{{role.id}}">
        <text class="role-name">{{role.name}}</text>
        <text class="expand-icon">{{expandedId === role.id ? '▼' : '▶'}}</text>
      </view>
      <view class="perm-list" wx:if="{{expandedId === role.id}}">
        <label class="perm-item" wx:for="{{allPermissions}}" wx:key="key" wx:for-item="perm">
          <checkbox value="{{perm.key}}" checked="{{role.permissions.includes('all') || role.permissions.includes(perm.key)}}" bindchange="onPermChange" data-role="{{role.id}}" data-perm="{{perm.key}}"/>
          <text class="perm-name">{{perm.name}}</text>
        </label>
      </view>
    </view>
  </block>
  <view class="save-area">
    <button class="btn-primary" bindtap="onSaveAll">保存所有角色权限</button>
  </view>
</view>
