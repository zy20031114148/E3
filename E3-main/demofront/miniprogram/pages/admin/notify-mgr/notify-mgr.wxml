<view class="page">
  <view class="card">
    <view class="flex-header">
      <text class="section-title">通知公告</text>
      <button class="add-btn" bindtap="onAdd">+ 发布</button>
    </view>
    <block wx:for="{{list}}" wx:key="id">
      <view class="notify-item">
        <view class="notify-info" bindtap="onDetail" data-item="{{item}}">
          <text class="notify-title">{{item.title}}</text>
          <text class="notify-time">{{item.createTime}}</text>
        </view>
        <view class="notify-actions">
          <text class="action-btn" bindtap="onEdit" data-item="{{item}}">编辑</text>
          <text class="action-btn action-del" bindtap="onDelete" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </block>
  </view>
</view>

<!-- 发布/编辑通知表单弹窗 -->
<view class="modal-mask" wx:if="{{showForm}}" bindtap="hideForm"></view>
<view class="form-modal" wx:if="{{showForm}}">
  <view class="modal-header">
    <text class="modal-title">{{formTitle}}</text>
    <text class="modal-close" bindtap="hideForm">✕</text>
  </view>
  <view class="modal-body">
    <view class="input-group">
      <text class="input-label">标题</text>
      <input class="input-field" value="{{form.title}}" bindinput="onInputChange" data-field="title" placeholder="请输入通知标题" />
    </view>
    <view class="input-group">
      <text class="input-label">内容</text>
      <textarea class="textarea-field" value="{{form.content}}" bindinput="onInputChange" data-field="content" placeholder="请输入通知内容" auto-height maxlength="-1" />
    </view>
    <view class="input-group">
      <text class="input-label">发布范围</text>
      <picker mode="selector" range="{{roleOptions}}" bindchange="onRoleChange">
        <view class="picker-field">{{roleOptions[form.targetRole === 'all' ? 0 : form.targetRole === 'visitor' ? 1 : form.targetRole === 'host' ? 2 : form.targetRole === 'admin' ? 3 : 4]}}</view>
      </picker>
    </view>
  </view>
  <view class="modal-footer">
    <button class="btn-cancel" bindtap="hideForm">取消</button>
    <button class="btn-primary" bindtap="onSave">保存</button>
  </view>
</view>

<!-- 通知详情弹窗 -->
<view class="modal-mask" wx:if="{{showDetail}}" bindtap="hideDetail"></view>
<view class="detail-modal" wx:if="{{showDetail}}">
  <view class="modal-header">
    <text class="modal-title">通知详情</text>
    <text class="modal-close" bindtap="hideDetail">✕</text>
  </view>
  <view class="modal-body">
    <text class="detail-title-text">{{detailItem.title}}</text>
    <text class="detail-time">{{detailItem.createTime}}</text>
    <view class="detail-divider"></view>
    <text class="detail-content">{{detailItem.content}}</text>
  </view>
  <view class="modal-footer">
    <button class="btn-primary" bindtap="hideDetail" style="flex:1;">关闭</button>
  </view>
</view>
