.page { padding-bottom: 40rpx; }

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}
.search-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  border: 2rpx solid #e8e8e8;
}
.search-btn {
  background: #1a7cee;
  color: #fff;
  font-size: 26rpx;
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  border: none;
  white-space: nowrap;
}

.emp-name {
  font-size: 30rpx;
  font-weight: 500;
}
.emp-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}
.emp-actions {
  display: flex;
  gap: 16rpx;
}
.action-btn {
  font-size: 24rpx;
  color: #1a7cee;
  padding: 6rpx 16rpx;
  border: 2rpx solid #1a7cee;
  border-radius: 8rpx;
}
.action-del {
  color: #ff4d4f;
  border-color: #ff4d4f;
}

/* 表单弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}
.form-modal {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  background: #fff;
  border-radius: 20rpx;
  z-index: 101;
  padding: 0;
  overflow: hidden;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.modal-title { font-size: 32rpx; font-weight: 600; }
.modal-close { font-size: 36rpx; color: #999; padding: 10rpx; }
.modal-body { padding: 30rpx; }
.modal-body .input-group {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}
.modal-body .input-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}
.modal-body .input-field {
  height: 76rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}
.modal-body .picker-field {
  height: 76rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  line-height: 76rpx;
  color: #333;
}
.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}
.btn-cancel {
  flex: 1;
  padding: 20rpx 0;
  background: #f5f6fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  border: none;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary {
  flex: 2;
  padding: 24rpx 0;
  background: #1a7cee;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #fff;
  border: none;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
