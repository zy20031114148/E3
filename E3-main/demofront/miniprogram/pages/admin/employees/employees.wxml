<view class="page has-tabbar">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索员工姓名" value="{{keyword}}" bindinput="onSearch" />
    <button class="search-btn" bindtap="onAdd">+ 新增</button>
  </view>

  <view class="card">
    <block wx:for="{{list}}" wx:key="id">
      <view class="list-item">
        <view>
          <text class="emp-name">{{item.name}}</text>
          <view class="emp-meta">{{item.department}} · {{item.position}} · {{item.phone}}</view>
        </view>
        <view class="emp-actions">
          <text class="action-btn" bindtap="onEdit" data-item="{{item}}">编辑</text>
          <text class="action-btn action-del" bindtap="onDelete" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </block>
  </view>

  <view class="empty-state" wx:if="{{list.length === 0}}">暂无员工数据</view>
</view>

<!-- 新增/编辑员工表单弹窗 -->
<view class="modal-mask" wx:if="{{showForm}}" bindtap="hideForm"></view>
<view class="form-modal" wx:if="{{showForm}}">
  <view class="modal-header">
    <text class="modal-title">{{formTitle}}</text>
    <text class="modal-close" bindtap="hideForm">✕</text>
  </view>
  <view class="modal-body">
    <view class="input-group">
      <text class="input-label">姓名</text>
      <input class="input-field" value="{{form.name}}" bindinput="onInputChange" data-field="name" placeholder="请输入姓名" />
    </view>
    <view class="input-group">
      <text class="input-label">手机号</text>
      <input class="input-field" type="number" value="{{form.phone}}" bindinput="onInputChange" data-field="phone" placeholder="请输入手机号" maxlength="11" />
    </view>
    <view class="input-group">
      <text class="input-label">部门</text>
      <picker mode="selector" range="{{departmentOptions}}" value="{{form.departmentId - 1}}" bindchange="onDepartmentChange">
        <view class="picker-field">{{form.department || '请选择部门'}}</view>
      </picker>
    </view>
    <view class="input-group">
      <text class="input-label">职位</text>
      <input class="input-field" value="{{form.position}}" bindinput="onInputChange" data-field="position" placeholder="请输入职位" />
    </view>
  </view>
  <view class="modal-footer">
    <button class="btn-cancel" bindtap="hideForm">取消</button>
    <button class="btn-primary" bindtap="onSave">保存</button>
  </view>
</view>

<tabBar activeTab="0"></tabBar>
