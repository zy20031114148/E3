<view class="page has-tabbar">
  <view class="tabs">
    <view class="tab {{currentTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="switchTab">全部</view>
    <view class="tab {{currentTab === 'pending' ? 'active' : ''}}" data-tab="pending" bindtap="switchTab">待审核</view>
    <view class="tab {{currentTab === 'approved' ? 'active' : ''}}" data-tab="approved" bindtap="switchTab">已通过</view>
  </view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="card">
      <view class="record-header">
        <text class="record-company">{{item.company}}</text>
        <text class="tag tag-{{item.status}}">{{statusMap[item.status]}}</text>
      </view>
      <view class="record-body">
        <view class="info-row"><text class="label">访客：</text><text>{{item.visitorName}}</text></view>
        <view class="info-row"><text class="label">被访人：</text><text>{{item.hostName}}</text></view>
        <view class="info-row"><text class="label">事由：</text><text>{{item.purpose}}</text></view>
        <view class="info-row"><text class="label">时间：</text><text>{{item.startTime}}</text></view>
      </view>
      <view class="record-actions" wx:if="{{item.status === 'pending'}}">
        <button class="btn-cancel" bindtap="onCancel" data-id="{{item.id}}">撤销预约</button>
      </view>
      <view class="record-actions" wx:if="{{item.status === 'approved'}}">
        <button class="btn-sm" bindtap="onShowQr" data-item="{{item}}">查看二维码</button>
        <button class="btn-sm btn-outline" bindtap="onRebook" data-id="{{item.id}}">再次预约</button>
      </view>
      <view class="greeting-area" wx:if="{{item.greeting && item.status === 'approved'}}" bindtap="onViewGreeting" data-item="{{item}}">
        <text class="greeting-icon">💬</text>
        <text class="greeting-text">点击查看迎接话术</text>
      </view>
    </view>
  </block>

  <view class="empty-state" wx:if="{{list.length === 0}}">暂无预约记录</view>

  <view class="card" style="margin-top: 0;">
    <view class="menu-item" bindtap="goNotices">
      <text class="menu-text">📢 查看通知公告</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
<tabBar activeTab="1"></tabBar>
