<scroll-view class="page has-tabbar" scroll-y>
  <view class="card">
    <view class="input-group">
      <text class="input-label">访客姓名</text>
      <input class="input-field" placeholder="请输入姓名" value="{{form.visitorName}}" bindinput="onFieldChange" data-field="visitorName"></input>
    </view>
    <view class="input-group">
      <text class="input-label">手机号</text>
      <input class="input-field" type="number" placeholder="请输入手机号" value="{{form.visitorPhone}}" bindinput="onFieldChange" data-field="visitorPhone"></input>
    </view>
    <view class="input-group">
      <text class="input-label">来访单位</text>
      <input class="input-field" placeholder="请输入单位名称" value="{{form.company}}" bindinput="onFieldChange" data-field="company"></input>
    </view>
    <view class="input-group">
      <text class="input-label">来访事由</text>
      <input class="input-field" placeholder="如：商务洽谈、技术交流" value="{{form.purpose}}" bindinput="onFieldChange" data-field="purpose"></input>
    </view>
    <view class="input-group">
      <text class="input-label">被访人</text>
      <picker class="picker" range="{{hostList}}" range-key="name" bindchange="onHostChange">
        <view class="picker-value">{{form.hostName || '请选择被访人'}}</view>
      </picker>
    </view>
    <view class="input-group">
      <text class="input-label">访问人数</text>
      <stepper class="stepper" min="1" max="20" value="{{form.visitorCount}}" bindchange="onCountChange"></stepper>
    </view>
    <view class="input-group">
      <text class="input-label">车牌号（选填）</text>
      <input class="input-field" placeholder="如：粤B12345" value="{{form.carPlate}}" bindinput="onFieldChange" data-field="carPlate"></input>
    </view>
    <view class="input-group">
      <text class="input-label">到访时间</text>
      <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
        <view class="picker-value">{{form.date || '请选择日期'}}</view>
      </picker>
    </view>
    <view class="input-group">
      <text class="input-label">备注（选填）</text>
      <textarea class="textarea-field" placeholder="如有特殊需求请备注" value="{{form.remark}}" bindinput="onFieldChange" data-field="remark"></textarea>
    </view>
  </view>

  <view class="submit-area">
    <button class="btn-primary" bindtap="onSubmit" loading="{{submitting}}">提交预约</button>
  </view>
  </scroll-view>
  <tabBar activeTab="0"></tabBar>
