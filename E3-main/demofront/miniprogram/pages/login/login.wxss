.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a7cee 0%, #3b9eff 40%, #f5f6fa 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  padding-bottom: 60rpx;
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.25);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.logo-text {
  font-size: 72rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 700;
}

.title {
  font-size: 44rpx;
  color: #fff;
  font-weight: 600;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
}

.login-form {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.08);
}

.login-btn {
  width: 100%;
  margin-top: 30rpx;
}

.demo-section {
  margin-top: 36rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}
.demo-title {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  display: block;
  margin-bottom: 20rpx;
}
.demo-accounts {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.demo-item {
  width: calc(50% - 8rpx);
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
  box-sizing: border-box;
  transition: all 0.2s;
}
.demo-item:active {
  background: #e8edf7;
}
.demo-role {
  font-size: 24rpx;
  color: #1a7cee;
  font-weight: 500;
  display: block;
}
.demo-info {
  font-size: 20rpx;
  color: #aaa;
  margin-top: 4rpx;
  display: block;
}
