/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f6fa;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #1a7cee, #3b9eff);
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary:active {
  opacity: 0.85;
}

/* 通用输入框 */
.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #e8e8e8;
}

/* 状态标签 */
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.tag-pending { background: #fff7e6; color: #fa8c16; }
.tag-approved { background: #f0fff5; color: #52c41a; }
.tag-rejected { background: #fff0f0; color: #ff4d4f; }
.tag-cancelled { background: #f5f5f5; color: #999; }
.tag-confirmed { background: #e6f7ff; color: #1890ff; }

/* 列表项 */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}
.list-item:last-child {
  border-bottom: none;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #bbb;
  font-size: 28rpx;
}

/* 有底部导航时页面底部留空 */
.has-tabbar {
  padding-bottom: 140rpx;
}

/* 菜单项 */
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}
.menu-item:last-child { border-bottom: none; }
.menu-text { font-size: 28rpx; color: #333; }
.menu-arrow { font-size: 36rpx; color: #ccc; }
